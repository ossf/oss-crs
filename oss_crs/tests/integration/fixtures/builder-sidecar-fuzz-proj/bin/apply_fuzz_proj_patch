#!/usr/bin/env python3
# SPDX-License-Identifier: MIT
"""Fuzz-proj patching integration test CRS:
  1. Call apply-patch-build with the bundled fuzz-proj diff
  2. Verify rebuild succeeded (exit code 0, rebuild_id written)
  3. Check response_dir/stdout.log for sentinel string written by patched build.sh
"""

import sys
from pathlib import Path

from libCRS.local import LocalCRSUtils

FUZZ_PROJ_DIFF = Path("/usr/local/bin/fuzz_proj_patch.diff")
RESPONSE_DIR = Path("/tmp/response")
SENTINEL = "fuzz_proj_patched_sentinel"


def log(msg: str) -> None:
    print(f"[apply-fuzz-proj-patch] {msg}", flush=True)


def main() -> int:
    crs = LocalCRSUtils()
    RESPONSE_DIR.mkdir(parents=True, exist_ok=True)

    log(f"Applying fuzz-proj patch: {FUZZ_PROJ_DIFF}")
    rc = crs.apply_patch_build(RESPONSE_DIR, fuzz_proj_patch_path=FUZZ_PROJ_DIFF)
    if rc != 0:
        stdout = (RESPONSE_DIR / "stdout.log").read_text(errors="replace") if (RESPONSE_DIR / "stdout.log").exists() else ""
        stderr = (RESPONSE_DIR / "stderr.log").read_text(errors="replace") if (RESPONSE_DIR / "stderr.log").exists() else ""
        log(f"apply_patch_build failed (exit={rc}):\nstdout:\n{stdout}\nstderr:\n{stderr}")
        return 1

    rid_file = RESPONSE_DIR / "rebuild_id"
    if not rid_file.exists():
        log("rebuild_id file missing from response dir")
        return 1
    rebuild_id = int(rid_file.read_text().strip())
    log(f"rebuild_id={rebuild_id}")

    stdout_path = RESPONSE_DIR / "stdout.log"
    if not stdout_path.exists():
        log("FAIL: stdout.log missing from response dir")
        return 1

    stdout_text = stdout_path.read_text(errors="replace")
    if SENTINEL not in stdout_text:
        log(f"FAIL: sentinel '{SENTINEL}' not found in stdout.log — patched image was NOT used")
        log(f"stdout.log contents:\n{stdout_text[:500]}")
        return 1

    log(f"SUCCESS: sentinel '{SENTINEL}' found in stdout.log — fuzz-proj patch applied and image rebuilt correctly")
    return 0


if __name__ == "__main__":
    sys.exit(main())
